{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git worktree:*)",
      "Bash(mvn:*)",
      "Bash(./mvnw:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(docker build:*)",
      "Bash(docker compose:*)",
      "Bash(podman build:*)",
      "Bash(oc get:*)",
      "Bash(oc describe:*)",
      "Bash(oc logs:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(helm template:*)",
      "Bash(helm lint:*)",
      "Bash(argocd app get:*)",
      "Bash(argocd app sync --dry-run:*)",
      "Bash(curl -sI:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "WebFetch(domain:openshift.io)",
      "WebFetch(domain:spring.io)",
      "WebFetch(domain:openapi.tools)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(sudo:*)",
      "Bash(su -:*)",
      "Bash(chmod 777:*)",
      "Bash(chown -R:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(eval:*)",
      "Bash(:(){ :|:& };:)",
      "Bash(dd if=:*)",
      "Bash(mkfs:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main --force:*)",
      "Bash(git reset --hard origin/main:*)",
      "Bash(git reset --hard HEAD~:*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref -d:*)",
      "Bash(git config --global user.email:*)",
      "Bash(npm install -g:*)",
      "Bash(pip install --break-system-packages:*)",
      "Bash(oc delete:*)",
      "Bash(kubectl delete:*)",
      "Bash(helm delete:*)",
      "Bash(argocd app delete:*)",
      "Bash(oc apply -f * --force:*)",
      "Bash(oc * --grace-period=0:*)",
      "Bash(oc patch * --type=json:*)",
      "Bash(oc * -n openshift-*:*)",
      "Bash(oc * -n kube-*:*)",
      "Bash(oc * -n default:*)",
      "Bash(oc login:*)",
      "Bash(docker push:*)",
      "Bash(docker rmi:*)",
      "Bash(docker system prune:*)",
      "Bash(podman push:*)",
      "Bash(:* > /etc/*)",
      "Bash(:* > /usr/*)",
      "Bash(:* > /sys/*)",
      "Bash(:* > /proc/*)",
      "Bash(mvn deploy:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/.kube/config)",
      "Read(**/.aws/credentials)",
      "Read(**/.docker/config.json)",
      "Edit(**/.env*)",
      "Edit(**/secrets/**)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(db/migrations/V*__*.sql)",
      "Edit(.github/workflows/*-prod.yml)",
      "Edit(deploy/argocd/apps/*-prod.yaml)",
      "Edit(gates/G*-signoff.md)"
    ]
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "600000"
  }
}
