{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "600000"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git push:*)",
      "Bash(git worktree:*)",
      "Bash(mvn:*)",
      "Bash(./mvnw:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(docker build:*)",
      "Bash(docker compose:*)",
      "Bash(podman build:*)",
      "Bash(curl -sI:*)",
      "Bash(jq:*)",
      "Bash(npm install:*)",
      "Bash(npm init:*)",
      "Bash(npm create:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(mkdir:*)",
      "Bash(chmod +x:*)",
      "Bash(chmod +X:*)",
      "Bash(cp:*)",
      "Bash(touch:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(test:*)",
      "Bash(java:*)",
      "Bash(tar:*)",
      "Bash(unzip:*)",
      "Bash(make:*)",
      "Bash(tree:*)",
      "Bash(sleep:*)",
      "Bash(date:*)",
      "Bash(whoami:*)",
      "Bash(id:*)",
      "Bash(uname:*)",
      "Bash(env:*)",
      "Bash(pip install:*)",
      "Bash(rm:*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "WebFetch(domain:spring.io)",
      "WebFetch(domain:openapi.tools)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(sudo:*)",
      "Bash(su -:*)",
      "Bash(chmod 777:*)",
      "Bash(chown -R:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(eval:*)",
      "Bash(dd if=:*)",
      "Bash(mkfs:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main --force:*)",
      "Bash(git reset --hard origin/main:*)",
      "Bash(git reset --hard HEAD~:*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref -d:*)",
      "Bash(git config --global user.email:*)",
      "Bash(npm install -g:*)",
      "Bash(pip install --break-system-packages:*)",
      "Bash(docker push:*)",
      "Bash(docker rmi:*)",
      "Bash(docker system prune:*)",
      "Bash(podman push:*)",
      "Bash(mvn deploy:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/.kube/config)",
      "Read(**/.aws/credentials)",
      "Read(**/.docker/config.json)",
      "Edit(**/.env*)",
      "Edit(**/secrets/**)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(db/migrations/V*__*.sql)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "kubernetes-operations@claude-code-workflows": true,
    "security-scanning@claude-code-workflows": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json;d=json.load(sys.stdin);f=d.get('tool_input',{}).get('file_path') or d.get('tool_response',{}).get('filePath','');print(f)\" | { read -r f; [ -n \"$f\" ] && git add \"$f\" 2>/dev/null; } || true",
            "timeout": 10,
            "statusMessage": "Auto-staging changed file"
          }
        ]
      }
    ]
  }
}
