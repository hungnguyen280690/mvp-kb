# CODEOWNERS — Phân vai review tự động theo path
# Tham chiếu: docs/GATEKEEPERS.md
# Cú pháp: <pattern> <@user1> <@user2> <@team>
# Reviewer được tag tự động khi PR đụng path tương ứng.

# ─────────────────────────────────────────────────
# Default — mọi file chưa match → Tech Lead
# ─────────────────────────────────────────────────
*                                @tech-lead

# ─────────────────────────────────────────────────
# Domain & contracts — High risk, cần G2 (SA)
# ─────────────────────────────────────────────────
/domain/**                       @ba-lead @sa-lead
/contracts/**                    @sa-lead @tech-lead
/contracts/openapi/**            @sa-lead @backend-lead
/contracts/asyncapi/**           @sa-lead @backend-lead
/contracts/schemas/**            @sa-lead @backend-lead @ba-lead
/db/migrations/**                @sa-lead @dba-lead

# ─────────────────────────────────────────────────
# Backend services — G3 (Java Lead)
# ─────────────────────────────────────────────────
/services/bff-service/**         @backend-lead
/services/ltt-core/**            @backend-lead @sa-lead
/services/integration-gateway/** @backend-lead @sa-lead
/services/gl-pusher/**           @backend-lead @sa-lead

# Critical paths — đòi 2 reviewer
/services/ltt-core/saga/**       @backend-lead @sa-lead
/services/ltt-core/audit/**      @backend-lead @sa-lead @security-lead
/services/ltt-core/outbox/**     @backend-lead @sa-lead
/services/**/auth/**             @backend-lead @security-lead
/services/**/signature/**        @backend-lead @security-lead
/services/**/idempotency/**      @backend-lead @sa-lead

# ─────────────────────────────────────────────────
# Frontend — G3' (Frontend Lead)
# ─────────────────────────────────────────────────
/frontend/**                     @frontend-lead
/frontend/src/auth/**            @frontend-lead @security-lead
/frontend/src/components/payment/** @frontend-lead @backend-lead

# ─────────────────────────────────────────────────
# Tests — G4 (QA Lead)
# ─────────────────────────────────────────────────
/tests/**                        @qa-lead
/tests/e2e/**                    @qa-lead @frontend-lead
/tests/perf/**                   @qa-lead @sre-lead
/tests/security/**               @qa-lead @security-lead

# ─────────────────────────────────────────────────
# DevOps & Infrastructure — G5 (SRE)
# ─────────────────────────────────────────────────
/deploy/**                       @sre-lead
/deploy/helm/**                  @sre-lead @backend-lead
/deploy/argocd/apps/*-prod.yaml  @sre-lead @tech-lead
/deploy/argocd/apps/*-uat.yaml   @sre-lead
/.tekton/**                      @sre-lead
/observability/**                @sre-lead
/observability/runbook/**        @sre-lead @backend-lead

# ─────────────────────────────────────────────────
# CI/CD — Tech Lead + SRE
# ─────────────────────────────────────────────────
/.github/workflows/**            @sre-lead @tech-lead
/.github/CODEOWNERS              @tech-lead @repo-admin
/.github/branch-protection*      @tech-lead @repo-admin

# ─────────────────────────────────────────────────
# Safety, policy, gates — Repo admin only
# ─────────────────────────────────────────────────
/docs/SAFETY.md                  @repo-admin @security-lead
/docs/QUALITY_GATES.md           @repo-admin @qa-lead @sre-lead
/docs/GATEKEEPERS.md             @repo-admin @tech-lead
/.claude/settings.json           @repo-admin @security-lead
/.claude/agents/**               @tech-lead
/gates/**                        @repo-admin

# ─────────────────────────────────────────────────
# Docs
# ─────────────────────────────────────────────────
/docs/**                         @tech-lead
/CLAUDE.md                       @tech-lead
/README.md                       @tech-lead
